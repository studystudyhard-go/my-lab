---
import { getCollection } from "astro:content"
import { sectionConfig } from "@my/config"
import { EntryCard } from "@/components/app/entry-card"
import { ModuleHeader } from "@/components/app/module-header"
import BaseLayout from "@/layouts/BaseLayout.astro"
import { filterVisibleCollectionEntries, sortEntriesByPublishedAt } from "@/lib/works"

const notes = sortEntriesByPublishedAt(filterVisibleCollectionEntries(await getCollection("lab")))
---

<BaseLayout title={sectionConfig.lab.label} description={sectionConfig.lab.description} currentPath="/lab">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 py-8 md:px-6">
    <ModuleHeader title={sectionConfig.lab.title} description={sectionConfig.lab.description} />
    <section class="grid gap-6 md:grid-cols-2">
      {notes.map((entry) => (
        <EntryCard
          title={entry.data.title}
          summary={entry.data.summary}
          meta={entry.data.status}
          tags={entry.data.tags}
          href={`/lab/${entry.id}`}
          image={entry.data.cardImage}
          imageAlt={entry.data.cardImageAlt}
        />
      ))}
    </section>
  </div>
</BaseLayout>
