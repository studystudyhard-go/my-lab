---
import { getCollection, render } from "astro:content"
import { DetailShell } from "@/components/app/detail-shell"
import { WorkMasonry } from "@/components/app/work-masonry"
import BaseLayout from "@/layouts/BaseLayout.astro"
import { getAllWorkMedia, getDisplayDate } from "@/lib/works"

export async function getStaticPaths() {
  const works = await getCollection("works")
  return works.map((entry) => ({ params: { slug: entry.id }, props: { entry } }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const displayDate = getDisplayDate(entry)
const galleryMedia = getAllWorkMedia(entry)
---

<BaseLayout title={entry.data.title} description={entry.data.summary} currentPath={`/works/${entry.id}`}>
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 py-8 md:px-6">
    <DetailShell
      title={entry.data.title}
      summary={entry.data.summary}
      tags={entry.data.tags}
      backHref="/"
      backLabel="返回作品展"
    >
      <WorkMasonry media={galleryMedia} displayDate={displayDate} />
      <div class="space-y-6 text-lg leading-9 text-muted-foreground [&_p]:leading-9">
        <Content />
      </div>
    </DetailShell>
  </div>
</BaseLayout>
