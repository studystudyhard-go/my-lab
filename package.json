{
  "name": "my-lab",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 pnpm --filter @my/site dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 pnpm --filter @my/site build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 pnpm --filter @my/site preview",
    "check": "mkdir -p apps/site/node_modules/.astro && ASTRO_TELEMETRY_DISABLED=1 pnpm --filter @my/site astro check"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
